# claude-code-task-dashboard — environment overrides.
# Copy to `.env` (gitignored) and set what you need. Everything has a safe default;
# the demo runs with none of these set.

# --- Demo mode -------------------------------------------------------------
# 1 = serve bundled mock fixtures (mocks/) instead of shelling out to a real
# workspace. No Python, no task store, no workspace required. Great for a first run.
DASHBOARD_DEMO=1

# --- Server ---------------------------------------------------------------
# Port for the localhost-only server (default 8790).
TASK_DASHBOARD_PORT=8790
# Log level: trace|debug|info|warn|error (default info).
LOG_LEVEL=info

# --- Real workspace mode (leave DASHBOARD_DEMO unset/0) -------------------
# Python interpreter used to run the workspace task-store scripts (default: python).
TASK_DASHBOARD_PYTHON=python
# Point the dashboard at a workspace root other than its own folder. The workspace
# must contain `.claude/scripts/` (burndown.py, closures-since.py, update-task.py, ...).
# TASK_DASHBOARD_WORKSPACE_ROOT=/path/to/your/claude/workspace

# --- Write-back (optional; POST /action) ----------------------------------
# Shared secret guarding every write. Empty => writes disabled (reads still work).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_WRITE_TOKEN=
# Disable the dashboard's auto-commit of its own write-backs (default: enabled).
# DASHBOARD_AUTO_COMMIT=false

# --- Mobile access via Cloudflare Tunnel (optional) -----------------------
# The public https origin of your tunnel; also accepted by the write Origin/Host guards.
# DASHBOARD_PUBLIC_ORIGIN=https://dash.example.com

# --- Offline durability outbox Worker (optional; see outbox-worker/) -------
# DASHBOARD_OUTBOX_URL=https://dashboard-outbox.<sub>.workers.dev
# DASHBOARD_OUTBOX_TOKEN=
# DASHBOARD_OUTBOX_ADMIN_TOKEN=

# --- Anthropic API direct-spend panel (optional) --------------------------
# Org admin-scoped key; enables the API spend reader. Absent => panel reads "unavailable".
# ANTHROPIC_ADMIN_API_KEY=
